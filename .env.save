 conda activate base
# Copilot API Configuration
COPILOT_API_KEY=your_copilot_api_key_here
COPILOT_MODEL=gpt-4-vision  # For image analysis capabilities
COPILOT_CONFIDENCE_THRESHOLD=0.75

# System Configuration
PYTHON_PORT=5001
EXPRESS_PORT=8080
CAMERA_INDEX=0
FACE_DB_PATH=./face_db

# Activity Detection Settings
ACTIVITY_ANALYSIS_ENABLED=true
SUSPICIOUS_ACTIVITY_THRESHOLD=0.7
ACTIVITY_LOG_SIZE=50
