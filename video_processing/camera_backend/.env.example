# ──────────────────────────────────────────────────────────────────────────────
# SecureView — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ──────────────────────────────────────────────────────────────────────────────

# Azure OpenAI / Microsoft Copilot credentials
# Get these from: https://portal.azure.com → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_API_KEY_HERE

# The deployment name you created in Azure OpenAI Studio
# (must support vision — gpt-4o or gpt-4-turbo with vision)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
